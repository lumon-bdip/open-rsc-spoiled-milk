{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spoiled-milk.invalid/remastered-sprites/set.schema.json",
  "title": "Spoiled Milk remastered sprite set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "setId",
    "displayName",
    "status",
    "contributor",
    "targets"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "setId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "displayName": {"type": "string", "minLength": 1},
    "status": {"enum": ["work", "ready", "retired"]},
    "notes": {"type": "string"},
    "contributor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "provenance"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "displayName": {"type": "string", "minLength": 1},
        "sourceCommit": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
        "sourceBatch": {"type": "string", "minLength": 1},
        "provenance": {"type": "string", "minLength": 1}
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyPrefix", "frames", "sizePolicy", "recolorPolicy", "alphaThreshold"],
        "properties": {
          "keyPrefix": {"type": "string", "minLength": 1},
          "frames": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pattern", "first", "count"],
            "properties": {
              "pattern": {"type": "string", "pattern": "^(frames|work)/.+%02d.+\\.png$"},
              "first": {"type": "integer", "minimum": 0},
              "count": {"type": "integer", "minimum": 1, "maximum": 255}
            }
          },
          "sizePolicy": {"const": "exact-canonical"},
          "recolorPolicy": {"enum": ["inherit", "none"]},
          "alphaThreshold": {"type": "integer", "minimum": 1, "maximum": 255},
          "legacySourceIds": {
            "type": "array",
            "items": {"type": "integer", "minimum": 0},
            "uniqueItems": true
          },
          "mappingConfidence": {"enum": ["confirmed", "provisional"]}
        }
      }
    }
  }
}
