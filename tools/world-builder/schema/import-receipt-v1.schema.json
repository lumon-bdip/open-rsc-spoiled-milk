{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spoiled-milk.invalid/world-builder/import-receipt-v1.schema.json",
  "title": "Spoiled Milk World Builder import receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestType",
    "transactionId",
    "status",
    "transactionType",
    "createdAtUtc",
    "layoutAdapter",
    "targetIdentitySha256",
    "targetFingerprintBeforeSha256",
    "exportManifestSha256",
    "selectedConfig",
    "revertsTransactionId",
    "files"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "manifestType": {"const": "world-builder-import-receipt"},
    "transactionId": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "status": {"enum": ["pending", "successful", "rolled-back", "reverted"]},
    "transactionType": {"enum": ["import", "rollback"]},
    "createdAtUtc": {"type": "string", "format": "date-time"},
    "layoutAdapter": {"type": "string", "minLength": 1},
    "targetIdentitySha256": {"$ref": "#/$defs/sha256"},
    "targetFingerprintBeforeSha256": {"$ref": "#/$defs/sha256"},
    "exportManifestSha256": {"$ref": "#/$defs/sha256"},
    "selectedConfig": {"type": "string", "pattern": "^server/.+\\.conf$"},
    "revertsTransactionId": {"type": "string", "pattern": "^$|^[A-Za-z0-9._-]+$"},
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/receiptFile"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "optionalSha256": {"type": "string", "pattern": "^$|^[0-9a-f]{64}$"},
    "receiptFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relativePath",
        "existedBefore",
        "beforeSha256",
        "installedPresent",
        "installedSha256",
        "backupRelativePath"
      ],
      "properties": {
        "relativePath": {"type": "string", "minLength": 1},
        "existedBefore": {"type": "boolean"},
        "beforeSha256": {"$ref": "#/$defs/optionalSha256"},
        "installedPresent": {"type": "boolean"},
        "installedSha256": {"$ref": "#/$defs/optionalSha256"},
        "backupRelativePath": {"type": "string"}
      }
    }
  }
}
