# Copy this file to server/local.env for local-only server launch settings.
# scripts/run-server.sh, scripts/run-server-zgc.sh, and scripts/run-hosted-server.sh load it automatically.

# Paste the Discord webhook URL between the quotes.
SPOILED_MILK_DISCORD_SHOWCASE_WEBHOOK=''

# Optional: defaults to true when a webhook URL is present.
SPOILED_MILK_DISCORD_SHOWCASE_ENABLED=true

# Optional: per-player cooldown for ::showitem / ::showoff.
SPOILED_MILK_DISCORD_SHOWCASE_COOLDOWN_SECONDS=60
